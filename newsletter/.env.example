# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Slack bot token — starts with xoxb-
# Get from: api.slack.com/apps → your app → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...

# Your Slack Member ID (not your username)
# Find it: Slack → click your profile picture → Profile → ··· menu → Copy member ID
SLACK_USER_ID=U0XXXXXXXXX
